{
  "name": "german-learning-app",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered German Language Learning Platform",
  "workspaces": [
    "frontend",
    "admin",
    "backend",
    "ai-engine"
  ],
  "scripts": {
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,scss,md}\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:admin": "npm run dev --prefix admin",
    "dev:backend": "npm run dev --prefix backend",
    "dev:ai": "npm run dev --prefix ai-engine",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:admin\"",
    "build": "npm run build --prefix frontend && npm run build --prefix admin",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:generate": "cd backend && npx prisma generate",
    "db:seed": "cd backend && node prisma/seed.js",
    "db:studio": "cd backend && npx prisma studio"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.4",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0",
    "concurrently": "^8.2.2"
  }
}